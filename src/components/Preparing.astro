---
// 準備中ページの共通コンポーネント（国東かいわいと同じ骨格）。
// 未公開セクションの URL に置き、公開時はページ本体を差し替えるだけにする。
import BaseLayout from '../layouts/BaseLayout.astro';

const { title, lang = 'jp' } = Astro.props;
const isEn = lang === 'en';
---

<BaseLayout title={title} lang={lang}>
  <section class="preparing">
    <h2>{title}</h2>
    {
      isEn ? (
        <p>
          This page is coming soon.
          <br />
          Please check back later.
        </p>
      ) : (
        <p>
          このページはただいま準備中です。
          <br />
          公開までいましばらくお待ちください。
        </p>
      )
    }
  </section>
</BaseLayout>

<style>
  .preparing {
    text-align: center;
    padding: 3rem 0 6rem;
  }

  .preparing p {
    color: var(--muted);
  }
</style>
